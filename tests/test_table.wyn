test "has name" {
    // Table formatting
    var name = "Alice"
    var age = "30"
    var row = "│ " + name + " │ " + age + " │"
    assert(row.contains("Alice"))
}

test "has age" {
    // Table formatting
    var name = "Alice"
    var age = "30"
    var row = "│ " + name + " │ " + age + " │"
    assert(row.contains("30"))
}

test "has border" {
    // Table formatting
    var name = "Alice"
    var age = "30"
    var row = "│ " + name + " │ " + age + " │"
    assert(row.contains("│"))
}

test "padded width" {
    // Table formatting
    var name = "Alice"
    var age = "30"
    var row = "│ " + name + " │ " + age + " │"
    // Padding
    var padded = name
    while padded.len() < 10 { padded = padded + " " }
    assert_eq(padded.len(), 10)
}
